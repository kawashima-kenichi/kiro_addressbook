# PostgreSQL Database
POSTGRES_DB=address_book
POSTGRES_USER=addressbook
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# Backend API
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_ISSUER=AddressBookAPI
JWT_AUDIENCE=AddressBookClient
JWT_EXPIRY_HOURS=24

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api

# Connection String (used by backend)
CONNECTION_STRING=Host=db;Database=address_book;Username=addressbook;Password=your_secure_password_here
