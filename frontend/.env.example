# ========================================
# フロントエンド環境変数設定
# ========================================

# API Base URL
# バックエンドAPIのベースURL
# 開発環境: http://localhost:5000
# 本番環境: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:5000

# API Timeout (ミリ秒)
# APIリクエストのタイムアウト時間
VITE_API_TIMEOUT=10000

# Enable Debug Mode
# デバッグモードを有効にする（開発環境のみ）
VITE_DEBUG_MODE=true
